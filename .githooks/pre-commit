#!/usr/bin/env python
"""Pre-commit hook: ensure CLAUDE.md and AGENTS.md stay in sync.

Enable once per clone with:

    git config core.hooksPath .githooks
"""
import subprocess
import sys
from pathlib import Path

try:
    repo_root = Path(
        subprocess.check_output(
            ["git", "rev-parse", "--show-toplevel"], text=True
        ).strip()
    )
except Exception:
    sys.exit(0)

claude = repo_root / "CLAUDE.md"
agents = repo_root / "AGENTS.md"

if not (claude.exists() and agents.exists()):
    sys.exit(0)

if claude.read_bytes() == agents.read_bytes():
    sys.exit(0)

sys.stderr.write(
    "\n[pre-commit] CLAUDE.md and AGENTS.md are out of sync.\n"
    "[pre-commit] Run `python scripts/check_docs_sync.py` for the line-level diff.\n"
    "[pre-commit] Fix the divergence and re-stage both files.\n\n"
)
sys.exit(1)
